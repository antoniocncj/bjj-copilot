# Azure Deployment Configuration
# This file contains Azure-specific configuration for the BJJ Copilot application

# Storage Account Configuration
STORAGE_ACCOUNT_SKU=Standard_LRS
STORAGE_ACCOUNT_KIND=StorageV2
STORAGE_LOCATION=East US

# Static Website Configuration
INDEX_DOCUMENT=index.html
ERROR_DOCUMENT=error.html

# CDN Configuration (Optional)
CDN_SKU=Standard_Microsoft
CDN_OPTIMIZATION_TYPE=GeneralWebDelivery

# Cache Control Headers
CACHE_CONTROL_HTML=max-age=3600
CACHE_CONTROL_ASSETS=max-age=31536000